        {
          "name": "2. LogIn",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Post-response script para guardar el token\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "console.log(\"Respuesta recibida:\", response);\r",
                  "\r",
                  "// Extraer el token de la estructura correcta\r",
                  "if (response.data && response.data.token) {\r",
                  "    const token = response.data.token;\r",
                  "    \r",
                  "    // Guardar token en variables de colección\r",
                  "    pm.collectionVariables.set(\"token\", token);\r",
                  "    \r",
                  "    // También guardar información del usuario si la necesitas\r",
                  "    if (response.data.user) {\r",
                  "        pm.collectionVariables.set(\"userId\", response.data.user._id);\r",
                  "        pm.collectionVariables.set(\"userEmail\", response.data.user.email);\r",
                  "        pm.collectionVariables.set(\"userName\", response.data.user.name);\r",
                  "    }\r",
                  "    \r",
                  "    console.log(\"✅ Token guardado exitosamente\");\r",
                  "    console.log(\"Token:\", token.substring(0, 50) + \"...\");\r",
                  "    \r",
                  "    // Test para verificar\r",
                  "    pm.test(\"Token guardado correctamente\", function () {\r",
                  "        pm.expect(pm.collectionVariables.get(\"token\")).to.not.be.empty;\r",
                  "    });\r",
                  "} else {\r",
                  "    console.error(\"❌ No se encontró token en response.data.token\");\r",
                  "    console.log(\"Estructura disponible:\", Object.keys(response));\r",
                  "    if (response.data) {\r",
                  "        console.log(\"Keys en data:\", Object.keys(response.data));\r",
                  "    }\r",
                  "}\r",
                  "\r",
                  "// Tests básicos\r",
                  "pm.test(\"Login exitoso - status 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Respuesta contiene token\", function () {\r",
                  "    pm.expect(response.data).to.have.property(\"token\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
